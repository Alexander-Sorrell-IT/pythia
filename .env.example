# Copy to .env and fill in. .env is gitignored.

# --- TWAK (Trust Wallet AgentKit) — execution layer ---
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=

# --- CoinMarketCap Agent Hub — data/signals layer ---
CMC_AGENT_HUB_KEY=
CMC_MCP_URL=

# --- Agent BSC wallet (dedicated; NOT your main wallet) ---
# Generate a fresh key: python -m src.wallet new
PRIVATE_KEY=
WALLET_PASSWORD=
NETWORK=bsc-testnet          # bsc-testnet for dev, bsc-mainnet for the live comp

# --- Risk guardrails (sane defaults; tune before live) ---
MAX_DRAWDOWN_PCT=25          # competition DQ gate is ~30%; stay under
MAX_TRADE_PCT=20             # max % of portfolio per single trade
MAX_DAILY_TRADES=12
MAX_SLIPPAGE_PCT=1.0
